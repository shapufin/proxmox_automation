# Environment Configuration for VMware-to-Proxmox Migration Tool
# Copy this to .env and update the values

# Database Configuration
POSTGRES_PASSWORD=your-secure-postgres-password
DJANGO_DB_NAME=vmware_to_proxmox
DJANGO_DB_USER=vmware_user
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432

# Django Configuration
DJANGO_SECRET_KEY=your-very-long-and-secret-django-key-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=false

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379/0

# Web Server Configuration
WEB_PORT=8000
WEB_CONCURRENCY=2
WORKER_CONCURRENCY=1

# Security (set to true in production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_SECURE=false

# Optional Monitoring
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
