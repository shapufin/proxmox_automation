# Environment Configuration for VMware-to-Proxmox Migration Tool
# Copy this to .env and update the values

# Database Configuration
POSTGRES_PASSWORD=your-secure-postgres-password
DJANGO_DB_NAME=vmware_to_proxmox
DJANGO_DB_USER=vmware_user
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432

# Django Configuration
DJANGO_SECRET_KEY=your-very-long-and-secret-django-key-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=false

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379/0

# Web Server Configuration
WEB_PORT=8000
WEB_CONCURRENCY=2
WORKER_CONCURRENCY=1

# Security (set to true in production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_SECURE=false

# Optional Monitoring
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── Auto Host Registration ─────────────────────────────────────────────────────
# Set AUTO_REGISTER=true to automatically upsert a ProxmoxHost DB record at
# container startup (run by the migrate init service and/or entrypoint.sh).
# The container will start even if the host is unreachable at boot time.
AUTO_REGISTER=false

PROXMOX_LABEL=Lab Proxmox
PROXMOX_NODE=proxmox-node-1
PROXMOX_API_HOST=10.10.10.1
PROXMOX_API_USER=root@pam
PROXMOX_API_TOKEN_NAME=migration
PROXMOX_API_TOKEN_VALUE=your-api-token-value-here
PROXMOX_API_VERIFY_SSL=false

PROXMOX_SSH_ENABLED=true
PROXMOX_SSH_HOST=10.10.10.1
PROXMOX_SSH_PORT=22
PROXMOX_SSH_USERNAME=root
PROXMOX_SSH_PASSWORD=your-proxmox-root-password
# PROXMOX_SSH_PRIVATE_KEY=   # paste PEM key as a single-line value if using key auth

PROXMOX_DEFAULT_STORAGE=local-lvm
PROXMOX_DEFAULT_BRIDGE=vmbr0
